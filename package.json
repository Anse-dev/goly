{
  "name": "goly",
  "displayName": "Goly — Git Worktree Manager",
  "description": "Run Git branches side by side. Manage worktrees, spot port conflicts, track coding agents, review changes, and restore context.",
  "version": "1.1.0",
  "publisher": "goly-dev",
  "icon": "media/logo.png",
  "repository": "https://github.com/Anse-dev/goly",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "git worktree",
    "worktree",
    "worktree manager",
    "parallel development",
    "branch manager",
    "pull request",
    "code review",
    "ai coding agents",
    "claude code",
    "codex",
    "cursor",
    "port monitor",
    "workspace manager",
    "developer tools"
  ],
  "activationEvents": [
    "onView:goly.sidebar",
    "onCommand:goly.refresh",
    "onCommand:goly.create",
    "onCommand:goly.review",
    "onCommand:goly.endReview",
    "onCommand:goly.snapshot",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goly.refresh",
        "title": "Goly: Refresh",
        "category": "Goly",
        "icon": "$(refresh)"
      },
      {
        "command": "goly.create",
        "title": "Goly: Create Worktree",
        "category": "Goly",
        "icon": "$(add)"
      },
      {
        "command": "goly.remove",
        "title": "Goly: Remove Worktree",
        "category": "Goly",
        "icon": "$(trash)"
      },
      {
        "command": "goly.open",
        "title": "Goly: Open in New Window",
        "category": "Goly",
        "icon": "$(window)"
      },
      {
        "command": "goly.terminal",
        "title": "Goly: Open Terminal Here",
        "category": "Goly",
        "icon": "$(terminal)"
      },
      {
        "command": "goly.snapshot",
        "title": "Goly: Save Snapshot",
        "category": "Goly",
        "icon": "$(save)"
      },
      {
        "command": "goly.restoreSnapshot",
        "title": "Goly: Restore Snapshot",
        "category": "Goly",
        "icon": "$(restore)"
      },
      {
        "command": "goly.review",
        "title": "Goly: Review Branch/PR",
        "category": "Goly",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "goly.endReview",
        "title": "Goly: End Review Session",
        "category": "Goly",
        "icon": "$(close)"
      },
      {
        "command": "goly.copyEnv",
        "title": "Goly: Copy Environment Files",
        "category": "Goly",
        "icon": "$(files)"
      },
      {
        "command": "goly.compare",
        "title": "Goly: Compare with Main",
        "category": "Goly",
        "icon": "$(diff)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "goly",
          "title": "Goly",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "goly": [
        {
          "id": "goly.sidebar",
          "name": "Worktrees"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "goly.sidebar",
        "contents": "No Git repository detected.\n\n[Open a folder with a Git repository](command:vscode.openFolder)\n\nor\n\n[Initialize Git](command:git.init)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "goly.refresh",
          "when": "view == goly.sidebar",
          "group": "navigation"
        },
        {
          "command": "goly.create",
          "when": "view == goly.sidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "goly.open",
          "when": "view == goly.sidebar && (viewItem == worktree || viewItem == mainWorktree)",
          "group": "inline"
        },
        {
          "command": "goly.terminal",
          "when": "view == goly.sidebar && (viewItem == worktree || viewItem == mainWorktree)"
        },
        {
          "command": "goly.snapshot",
          "when": "view == goly.sidebar && (viewItem == worktree || viewItem == mainWorktree)"
        },
        {
          "command": "goly.compare",
          "when": "view == goly.sidebar && viewItem == worktree"
        },
        {
          "command": "goly.copyEnv",
          "when": "view == goly.sidebar && viewItem == worktree"
        },
        {
          "command": "goly.remove",
          "when": "view == goly.sidebar && viewItem == worktree"
        }
      ]
    },
    "keybindings": [
      {
        "command": "goly.refresh",
        "key": "ctrl+shift+g r",
        "mac": "cmd+shift+g r",
        "when": "gitRepositoryExists"
      },
      {
        "command": "goly.create",
        "key": "ctrl+shift+g n",
        "mac": "cmd+shift+g n",
        "when": "gitRepositoryExists"
      }
    ],
    "configuration": {
      "title": "Goly",
      "properties": {
        "goly.baseDirectory": {
          "type": "string",
          "default": "~/workspaces",
          "description": "Default directory for new worktrees"
        },
        "goly.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh sidebar on file system changes"
        },
        "goly.refreshInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 0,
          "description": "Auto refresh interval in milliseconds (0 to disable)"
        },
        "goly.autoOpenInNewWindow": {
          "type": "boolean",
          "default": true,
          "description": "Open new worktree in a new VS Code window"
        },
        "goly.confirmBeforeDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation before deleting worktree"
        },
        "goly.confirmBeforeDeleteBranch": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation before deleting branch with worktree"
        },
        "goly.envFilePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env",
            ".env.local",
            ".env.*",
            "*.env"
          ],
          "description": "File patterns to copy to new worktrees"
        },
        "goly.postCreateCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "npm install"
          ],
          "description": "Commands to run after creating a worktree"
        },
        "goly.maxWorktrees": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum additional worktrees (0 for unlimited)"
        }
      }
    }
  },
  "homepage": "https://github.com/Anse-dev/goly#readme",
  "bugs": {
    "url": "https://github.com/Anse-dev/goly/issues"
  },
  "galleryBanner": {
    "color": "#070A0D",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Goly runs Git and configured post-create commands, so workspace trust is required."
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run typecheck && npm run build:extension",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --platform=node --external:vscode --external:esbuild",
    "build:integration": "esbuild src/test/runTest.ts src/test/integration/index.ts --bundle --platform=node --format=cjs --outbase=src/test --outdir=out/test --external:vscode",
    "watch": "npm run build:extension -- --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "npm run build && npm run build:integration && node ./out/test/runTest.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.ts\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "1.100.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@vscode/test-electron": "^2.3.10",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.7"
  }
}
